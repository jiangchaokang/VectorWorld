---
import type { ImageMetadata } from "astro";
import { Picture as AstroPicture } from "astro:assets";
import { renderPDF } from "../lib/render-pdf";

interface Props {
  src: ImageMetadata | `${string}.pdf`;
  alt: string;
  priority?: boolean;
  invertInDarkMode?: boolean;
  class?: string;
  expandable?: boolean;
  lightboxCaption?: string;
  lightboxOriginal?: string;
}

const {
  src,
  alt,
  priority = false,
  invertInDarkMode = false,
  class: className = "",
  expandable = false,
  lightboxCaption = alt,
  lightboxOriginal,
} = Astro.props;

let image: ImageMetadata;

if (typeof src === "string") {
  image = await renderPDF(src);
} else {
  image = src;
}

const pictureClass = [
  "mx-auto block max-w-full rounded-xl",
  invertInDarkMode ? "dark:invert" : "",
  className,
]
  .filter(Boolean)
  .join(" ");

const expandAriaLabel = alt ? `Expand image: ${alt}` : "Expand image";
---

{
  expandable ? (
    <button
      type="button"
      data-lightbox-trigger
      data-lightbox-src={image.src}
      data-lightbox-alt={alt}
      data-lightbox-caption={lightboxCaption}
      data-lightbox-original={lightboxOriginal}
      aria-label={expandAriaLabel}
      class="group relative block w-full cursor-zoom-in appearance-none border-0 bg-transparent p-0 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:focus-visible:ring-offset-zinc-900"
    >
      <AstroPicture
        class={pictureClass}
        src={image}
        alt={alt}
        layout="constrained"
        formats={["avif"]}
        priority={priority}
        fit="contain"
      />

      <span class="pointer-events-none absolute right-3 top-3 rounded-full border border-zinc-200 bg-white/92 px-3 py-1 text-xs font-medium text-zinc-700 shadow-sm opacity-0 transition duration-200 group-hover:opacity-100 dark:border-zinc-700 dark:bg-zinc-900/92 dark:text-zinc-200">
        Click to zoom
      </span>
    </button>
  ) : (
    <AstroPicture
      class={pictureClass}
      src={image}
      alt={alt}
      layout="constrained"
      formats={["avif"]}
      priority={priority}
      fit="contain"
    />
  )
}