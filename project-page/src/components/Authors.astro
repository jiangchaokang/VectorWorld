---
import type { Author } from "../types/types";

interface Props {
  authors: Author[];
}

const { authors } = Astro.props;

const institutions: string[] = [];
const institutionMap = new Map<string, number>();

for (const author of authors) {
  const institution = author.institution?.trim();
  if (!institution) continue;

  if (!institutionMap.has(institution)) {
    institutionMap.set(institution, institutions.length + 1);
    institutions.push(institution);
  }
}

function getSuperscripts(author: Author) {
  const parts: string[] = [];

  const institution = author.institution?.trim();
  if (institution) {
    const index = institutionMap.get(institution);
    if (index) parts.push(String(index));
  }

  const noteSymbols = (author.notes ?? [])
    .map((item) => item.trim())
    .filter((item) => item.length > 0);

  noteSymbols.forEach((item) => parts.push(item));

  return parts;
}

const authorBaseClass =
  "inline-flex items-center rounded-full border border-zinc-200 bg-white/92 px-4 py-2.5 text-sm font-semibold text-zinc-800 shadow-sm backdrop-blur transition duration-200 dark:border-zinc-800 dark:bg-zinc-900/88 dark:text-zinc-100";

const authorInteractiveClass =
  "hover:-translate-y-0.5 hover:border-blue-300 hover:text-blue-700 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white dark:hover:border-blue-400 dark:hover:text-blue-300 dark:focus-visible:ring-offset-zinc-900";

const affiliationClass =
  "inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-zinc-50/92 px-3 py-1.5 text-sm text-zinc-700 shadow-sm dark:border-zinc-800 dark:bg-zinc-950/88 dark:text-zinc-300";
---

{
  authors.length > 0 && (
    <div class="not-prose w-full max-w-4xl">
      <div class="flex flex-wrap items-center justify-center gap-3">
        {authors.map((author) => {
          const superscripts = getSuperscripts(author);

          return author.url ? (
            <a
              href={author.url}
              target="_blank"
              rel="noreferrer"
              aria-label={author.name}
              class:list={[authorBaseClass, authorInteractiveClass]}
            >
              <span class="tracking-tight">
                {author.name}
                {superscripts.length > 0 && (
                  <sup class="ml-1 text-xs font-semibold text-blue-600 dark:text-blue-300">
                    {superscripts.join(",")}
                  </sup>
                )}
              </span>
            </a>
          ) : (
            <span class={authorBaseClass}>
              <span class="tracking-tight">
                {author.name}
                {superscripts.length > 0 && (
                  <sup class="ml-1 text-xs font-semibold text-blue-600 dark:text-blue-300">
                    {superscripts.join(",")}
                  </sup>
                )}
              </span>
            </span>
          );
        })}
      </div>

      {institutions.length > 0 && (
        <div class="mt-4 flex flex-wrap items-center justify-center gap-2.5">
          {institutions.map((institution, index) => (
            <div class={affiliationClass}>
              <span class="inline-flex h-5 min-w-5 items-center justify-center rounded-full bg-blue-600 px-1.5 text-xs font-semibold text-white dark:bg-blue-500">
                {index + 1}
              </span>
              <span>{institution}</span>
            </div>
          ))}
        </div>
      )}
    </div>
  )
}