---
import Authors from "../Authors.astro";
import Links from "../Links.astro";
import Notes from "../Notes.astro";
import ThemeToggle from "../ThemeToggle.astro";
import VectorWorldWordmark from "./VectorWorldWordmark.astro";
import type { Author, Link, Note } from "../../types/types";

interface Props {
  title: string;
  authors: Author[];
  conference?: string;
  notes?: Note[];
  links?: Link[];
  description?: string;
  highlights?: string[];
}

const {
  title,
  authors,
  conference,
  notes,
  links,
  description,
  highlights = [],
} = Astro.props;

const [candidateBrand, candidateRest] = title.split(/:\s*/, 2);
const brand = candidateRest ? candidateBrand.trim() : "";
const subtitle = candidateRest ? candidateRest.trim() : title;
const heroHighlights = highlights.slice(0, 4);
const showBrandIcon = brand.trim().toLowerCase() === "vectorworld";
---

<header class="mx-auto mb-12 px-6 md:mb-16" style="max-width: 92rem;">
  <div class="vw-hero-shell px-6 py-6 md:px-10 md:py-10">
    <div class="mb-6 flex items-center justify-between gap-4">
      <span class="vw-eyebrow">Project page</span>
      <ThemeToggle />
    </div>

    <div class="mx-auto max-w-5xl text-center">
      {brand && (
        <div class="vw-hero-brand-wrap">
          <span class="vw-hero-brand">
            {showBrandIcon ? (
              <VectorWorldWordmark title={brand} iconSize="0.92em" />
            ) : (
              <span class="vw-hero-brand-fallback">{brand}</span>
            )}
          </span>
        </div>
      )}

      <h1 class={brand ? "vw-hero-subtitle" : "vw-hero-title"}>
        {brand && <span class="sr-only">{brand}: </span>}
        {subtitle}
      </h1>

      {description && (
        <p class="not-prose mx-auto mt-5 max-w-4xl vw-lead">
          {description}
        </p>
      )}

      <div class="not-prose mt-7 flex flex-col items-center gap-4">
        <Authors authors={authors} />

        <div class="flex flex-wrap items-center justify-center gap-3">
          {conference && <div class="vw-eyebrow">{conference}</div>}
          {notes && notes.length > 0 && <Notes notes={notes} />}
        </div>

        {links && links.length > 0 && <Links links={links} />}
      </div>
    </div>

    {heroHighlights.length > 0 && (
      <div class="not-prose mx-auto mt-8 grid max-w-6xl gap-3 md:grid-cols-2 xl:grid-cols-4">
        {heroHighlights.map((item, index) => (
          <article class="vw-hero-highlight-card">
            <div class="vw-hero-highlight-index">0{index + 1}</div>
            <p class="vw-hero-highlight-copy">{item}</p>
          </article>
        ))}
      </div>
    )}
  </div>
</header>