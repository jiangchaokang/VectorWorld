---
import Video from "../Video.astro";

type BadgeTone = "blue" | "zinc";

interface Props {
  caseTitle: string;
  subtitle: string;
  badge: string;
  badgeTone?: BadgeTone;
  vectorSrc: string;
  layoutSrc: string;
  resultSrc: string;
  vectorCaption?: string;
  layoutCaption?: string;
  resultCaption?: string;
}

const {
  caseTitle,
  subtitle,
  badge,
  badgeTone = "blue",
  vectorSrc,
  layoutSrc,
  resultSrc,
  vectorCaption =
    "Compact control input. It stays visually lighter so the projected layout and final synthesis remain the focus.",
  layoutCaption =
    "Projected control signal in image space. This is the key bridge between the explicit vector scene and the video generator.",
  resultCaption =
    "Final surround-view synthesis conditioned on the projected layout prior.",
} = Astro.props;

const badgeClass =
  badgeTone === "blue"
    ? "bg-blue-100 text-blue-700 dark:bg-blue-500/10 dark:text-blue-300"
    : "bg-zinc-100 text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300";

const frameHeightClass = "flex h-56 items-center justify-center md:h-64 xl:h-72";
---

<article class="vw-card p-5 md:p-6">
  <div class="mb-5 flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <h3 class="m-0 text-2xl font-semibold text-zinc-900 dark:text-zinc-50">
        {caseTitle}
      </h3>

      <p class="mt-1 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
        {subtitle}
      </p>
    </div>

    <span class:list={["rounded-full px-3 py-1 text-xs font-medium", badgeClass]}>
      {badge}
    </span>
  </div>

  <div class="grid gap-4 xl:grid-cols-12">
    <section class="rounded-2xl border border-zinc-200 bg-zinc-50/90 p-4 shadow-sm dark:border-zinc-800 dark:bg-zinc-950/70 xl:col-span-3">
      <div class="mb-3 flex items-center justify-between gap-3">
        <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">
          Stage 1 · Vector scene
        </p>

        <span class="rounded-full bg-zinc-200 px-2.5 py-1 text-xs font-medium text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300">
          Control input
        </span>
      </div>

      <div class="overflow-hidden rounded-2xl border border-zinc-200 bg-zinc-950 shadow-inner dark:border-zinc-800">
        <div class={frameHeightClass}>
          <Video
            src={vectorSrc}
            controls={true}
            autoplay={false}
            loop={false}
            muted={true}
            preload="none"
            class="!h-full !w-full object-contain"
          />
        </div>
      </div>

      <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
        {vectorCaption}
      </p>
    </section>

    <section class="rounded-2xl border border-blue-200 bg-blue-50/70 p-4 shadow-sm dark:border-blue-500/20 dark:bg-blue-500/5 xl:col-span-4">
      <div class="mb-3 flex items-center justify-between gap-3">
        <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">
          Stage 2 · Projected layout
        </p>

        <span class="rounded-full bg-blue-100 px-2.5 py-1 text-xs font-medium text-blue-700 dark:bg-blue-500/10 dark:text-blue-300">
          Explicit conditioning
        </span>
      </div>

      <div class="overflow-hidden rounded-2xl border border-blue-200 bg-zinc-950 shadow-inner dark:border-blue-500/20">
        <div class={frameHeightClass}>
          <Video
            src={layoutSrc}
            controls={true}
            autoplay={false}
            loop={false}
            muted={true}
            preload="none"
            class="!h-full !w-full object-contain"
          />
        </div>
      </div>

      <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
        {layoutCaption}
      </p>
    </section>

    <section class="rounded-2xl border border-violet-200 bg-violet-50/70 p-4 shadow-sm dark:border-violet-500/20 dark:bg-violet-500/5 xl:col-span-5">
      <div class="mb-3 flex items-center justify-between gap-3">
        <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">
          Stage 3 · Surround-view result
        </p>

        <span class="rounded-full bg-violet-100 px-2.5 py-1 text-xs font-medium text-violet-700 dark:bg-violet-500/10 dark:text-violet-300">
          Final output
        </span>
      </div>

      <div class="overflow-hidden rounded-2xl border border-violet-200 bg-zinc-950 shadow-inner dark:border-violet-500/20">
        <div class={frameHeightClass}>
          <Video
            src={resultSrc}
            controls={true}
            autoplay={false}
            loop={false}
            muted={true}
            preload="none"
            class="!h-full !w-full object-contain"
          />
        </div>
      </div>

      <p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400">
        {resultCaption}
      </p>
    </section>
  </div>
</article>