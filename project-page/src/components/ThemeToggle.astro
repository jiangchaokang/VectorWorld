---
import { Icon } from "astro-icon/components";

const options = [
  { value: "light", label: "Light", icon: "ri:sun-line" },
  { value: "dark", label: "Dark", icon: "ri:moon-clear-line" },
  { value: "device", label: "Auto", icon: "ri:computer-line" },
];
---

<div
  data-theme-toggle
  role="radiogroup"
  aria-label="Theme selector"
  class="not-prose inline-flex items-center gap-1 rounded-full border border-zinc-200 bg-white/90 p-1 shadow-sm backdrop-blur dark:border-zinc-800 dark:bg-zinc-900/90"
>
  {
    options.map((option) => (
      <button
        type="button"
        role="radio"
        data-theme-option={option.value}
        aria-checked="false"
        class="inline-flex items-center gap-2 rounded-full px-3 py-2 text-xs font-semibold text-zinc-500 transition hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
      >
        <Icon name={option.icon} class="h-4 w-4 shrink-0" />
        <span>{option.label}</span>
      </button>
    ))
  }
</div>

<script is:inline>
  (() => {
    const STORAGE_KEY = "vectorworld-theme";

    const activeClasses = [
      "bg-zinc-900",
      "text-white",
      "shadow-sm",
      "dark:bg-zinc-100",
      "dark:text-zinc-900",
    ];

    const inactiveClasses = [
      "text-zinc-500",
      "dark:text-zinc-400",
    ];

    const readStoredTheme = () => {
      try {
        return window.localStorage.getItem(STORAGE_KEY);
      } catch {
        return null;
      }
    };

    const writeStoredTheme = (value) => {
      try {
        window.localStorage.setItem(STORAGE_KEY, value);
      } catch {
        // ignore storage errors
      }
    };

    const applyTheme = (theme, buttons) => {
      document.documentElement.dataset.theme = theme;

      buttons.forEach((button) => {
        const isActive = button.dataset.themeOption === theme;

        button.setAttribute("aria-checked", String(isActive));

        activeClasses.forEach((className) =>
          button.classList.toggle(className, isActive),
        );

        inactiveClasses.forEach((className) =>
          button.classList.toggle(className, !isActive),
        );
      });
    };

    const setupGroup = (group) => {
      if (!(group instanceof HTMLElement)) return;
      if (group.dataset.ready === "true") return;
      group.dataset.ready = "true";

      const buttons = Array.from(
        group.querySelectorAll("button[data-theme-option]"),
      );

      const initial =
        readStoredTheme() ??
        document.documentElement.dataset.theme ??
        "device";

      applyTheme(initial, buttons);

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const nextTheme = button.dataset.themeOption ?? "device";
          writeStoredTheme(nextTheme);
          applyTheme(nextTheme, buttons);
        });
      });
    };

    const setup = () => {
      document.querySelectorAll("[data-theme-toggle]").forEach(setupGroup);
    };

    setup();
    document.addEventListener("astro:after-swap", setup);
  })();
</script>